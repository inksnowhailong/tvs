{
    "compilerOptions": {
        "isolatedModules": true,
        "target": "esnext",
        "experimentalDecorators": true,
        "useDefineForClassFields": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "sourceMap": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["esnext"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "types": ["@dcloudio/types", "@uni-helper/uni-app-types"]
    },
    "include": [
        "src/*.ts",
        "src/*.d.ts",
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "components.d.ts",
        "auto-imports.d.ts",
        "uno.config.ts",
        "vite.config.ts"
    ]
}
